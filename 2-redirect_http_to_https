global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

    # SSL Settings
    maxconn 2048
    tune.ssl.default-dh-param 2048

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    timeout connect 5000
    timeout client  50000
    timeout server  50000

# HTTPS Frontend - Handles secure traffic on port 443
frontend www-https
    bind *:443 ssl crt /etc/haproxy/certs/www.ganzagavin.tech.pem
    http-request set-header X-Forwarded-Proto https
    default_backend web-backend

# HTTP Frontend - Redirects all port 80 traffic to HTTPS with a 301 code
frontend www-http
    bind *:80
    http-request redirect scheme https code 301

# Backend - Points to your two web servers
backend web-backend
    balance roundrobin
    server 6984-web-01 18.233.155.106:80 check
    server 6984-web-02 52.91.168.56:80 check