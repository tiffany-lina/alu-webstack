#!/usr/bin/env bash
# 0-world_wide_web - Displays DNS info for subdomains using dig and awk

# Function to fetch and display DNS record info
audit_dns() {
    local domain=$1
    local subdomain=$2

    # Querying the A record and parsing with awk
    # shellcheck disable=SC2086
    dig "${subdomain}.${domain}" | grep -A1 'ANSWER SECTION:' | grep -v 'ANSWER SECTION' | awk -v subdom="$subdomain" '
    {
        printf "The subdomain %s is a %s record and points to %s\n", subdom, $4, $5
    }'
}

# Assign arguments
DOMAIN=$1
SPECIFIC_SUB=$2

if [ -n "$SPECIFIC_SUB" ]; then
    # If a specific subdomain is provided
    audit_dns "$DOMAIN" "$SPECIFIC_SUB"
else
    # Default list in specified order
    audit_dns "$DOMAIN" "www"
    audit_dns "$DOMAIN" "lb-01"
    audit_dns "$DOMAIN" "web-01"
    audit_dns "$DOMAIN" "web-02"
fi