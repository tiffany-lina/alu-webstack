#!/usr/bin/env bash
# Displays subdomain A records using dig and awk with nip.io

display_subdomain() {
    local sub=$1
    local domain=$2
    local ip=$(dig $sub.$domain | awk '/IN[[:space:]]A/ {print $5}')
    echo "The subdomain $sub is a A record and points to $ip"
}

domain=$1
subdomain=$2

# Map each subdomain to its correct nip.io domain
declare -A sub_domains
sub_domains=( ["www"]="44.212.25.228.nip.io" ["lb-01"]="44.212.25.228.nip.io" ["web-01"]="34.203.218.185.nip.io" ["web-02"]="44.202.164.145.nip.io" )

subs=("www" "lb-01" "web-01" "web-02")

if [ -z "$subdomain" ]; then
    for s in "${subs[@]}"; do
        display_subdomain $s ${sub_domains[$s]}
    done
else
    display_subdomain $subdomain ${sub_domains[$subdomain]}
fi
