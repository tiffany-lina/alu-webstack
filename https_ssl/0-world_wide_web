#!/usr/bin/env bash
# This script displays DNS record info for subdomains using awk and dig

domain=$1
subdomain=$2

# Function to get subdomain info
get_subdomain_info() {
    local sub=$1
    ip=$(dig +short "$sub.$domain")
    # Use awk to parse and print
    echo "$sub $ip" | awk '{print "The subdomain "$1" is a A record and points to "$2}'
}

# If subdomain is provided
if [ -n "$subdomain" ]; then
    get_subdomain_info "$subdomain"
else
    # Default subdomains in order
    for sub in www lb-01 web-01 web-02; do
        get_subdomain_info "$sub"
    done
fi
