#!/usr/bin/env bash
# Audits subdomain records for a given domain

domain=$1
subdomain=$2

# Function to display subdomain info
get_subdomain_info() {
    local sub=$1
    local target=$sub

    # Force www to point to lb-01
    if [ "$sub" == "www" ]; then
        target="lb-01"
    fi

    # Get A record from DNS
    local ip
    ip=$(dig +short ${target}.${domain})

    # Output in required format
    if [ -n "$ip" ]; then
        echo "The subdomain $sub is a A record and points to $ip"
    fi
}

# If no subdomain is provided, check all four in order
if [ -z "$subdomain" ]; then
    for sub in www lb-01 web-01 web-02; do
        get_subdomain_info "$sub"
    done
else
    get_subdomain_info "$subdomain"
fi
