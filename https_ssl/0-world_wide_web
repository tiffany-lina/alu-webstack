#!/usr/bin/env bash
# This script audits subdomains for a given domain and displays their record type and IP address

DOMAIN=$1
SUBDOMAIN=$2

# Function to display subdomain info
get_subdomain_info() {
    local sd="$1"
    local ip record
    ip=$(dig "${sd}.${DOMAIN}" +short)
    record="A"
    echo "The subdomain ${sd} is a ${record} record and points to ${ip}"
}

if [ -z "$SUBDOMAIN" ]; then
    # No specific subdomain provided; show default list
    for sub in www lb-01 web-01 web-02; do
        get_subdomain_info "$sub"
    done
else
    # Specific subdomain provided
    get_subdomain_info "$SUBDOMAIN"
fi
