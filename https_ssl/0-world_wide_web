#!/usr/bin/env bash
# Script that audits subdomains for a given domain

# Function to display subdomain info
display_subdomain() {
    local subdomain=$1
    local domain=$2

    # Get dig output for A record
    local info=$(dig $subdomain.$domain | awk '/ANSWER SECTION:/ {getline; print}')
    
    # Parse using awk
    local record_type=$(echo $info | awk '{print $4}')
    local destination=$(echo $info | awk '{print $5}')

    echo "The subdomain $subdomain is a $record_type record and points to $destination"
}

# Main
domain=$1
subdomain=$2

# Ordered subdomains for domain-only audit
subdomains=("www" "lb-01" "web-01" "web-02")

if [ -z "$subdomain" ]; then
    # Only domain provided
    for sd in "${subdomains[@]}"; do
        display_subdomain $sd $domain
    done
else
    # Domain + subdomain provided
    display_subdomain $subdomain $domain
fi
