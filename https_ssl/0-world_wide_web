#!/usr/bin/env bash
# This script displays DNS record information for subdomains using awk

domain=$1
subdomain=$2

# Function to get DNS info
get_info() {
    full_domain=$1
    ip=$(dig +short "$full_domain")

    echo "$full_domain $ip" | awk '{print "The subdomain "$1" is a A record and points to "$2}'
}

# If subdomain is provided
if [ -n "$subdomain" ]; then
    get_info "$subdomain"
else
    get_info "www.44.212.25.228.nip.io"
    get_info "lb-01.44.212.25.228.nip.io"
    get_info "web-01.34.203.218.185.nip.io"
    get_info "web-02.44.202.164.145.nip.io"
fi
