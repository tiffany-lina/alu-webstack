#!/usr/bin/env bash
# 0-world_wide_web: display info about subdomains of a domain

# Function to show subdomain info
get_subdomain_info() {
    local domain=$1
    local sub=$2
    # Use dig to get the A record
    local record=$(dig ${sub}.${domain} +short)
    if [ -n "$record" ]; then
        echo "The subdomain $sub is a A record and points to $record"
    else
        echo "The subdomain $sub does not exist or has no A record"
    fi
}

domain=$1
subdomain=$2

if [ -z "$subdomain" ]; then
    # Display all subdomains in the specific order
    for sub in www lb-01 web-01 web-02; do
        get_subdomain_info $domain $sub
    done
else
    # Display only the specified subdomain
    get_subdomain_info $domain $subdomain
fi
