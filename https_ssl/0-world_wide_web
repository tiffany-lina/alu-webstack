#!/usr/bin/env bash
# Script to show subdomain info for a domain

domain=$1      # First argument = domain
subdomain=$2   # Second argument = optional subdomain

# Function to get info for one subdomain
get_info() {
    local sub=$1
    # Use dig to get DNS info, grep for ANSWER SECTION, take the last line
    result=$(dig "$sub.$domain" | grep -A1 "ANSWER SECTION:" | tail -n1)
    # Extract record type and destination IP using awk
    record_type=$(echo "$result" | awk '{print $4}')
    destination=$(echo "$result" | awk '{print $5}')
    # Print formatted output
    echo "The subdomain $sub is a $record_type record and points to $destination"
}

# If a specific subdomain is provided, show only that one
if [ -n "$subdomain" ]; then
    get_info "$subdomain"
else
    # Otherwise, show all 4 subdomains in this order
    get_info "www"
    get_info "lb-01"
    get_info "web-01"
    get_info "web-02"
fi
