#!/usr/bin/env bash
# 0-world_wide_web: Display information about subdomains

# Function to fetch subdomain info
get_subdomain_info() {
    local domain=$1
    local subdomain=$2

    # +short returns only the IP
    local ip=$(dig +short ${subdomain}.${domain})
    
    # Get the record type (A, CNAME, etc.)
    local record_type=$(dig ${subdomain}.${domain} | awk '/IN/ {print $4; exit}')

    echo "The subdomain $subdomain is a $record_type record and points to $ip"
}

domain=$1
subdomain=$2

# If only domain is given, show info for all subdomains
if [ -z "$subdomain" ]; then
    for sub in www lb-01 web-01 web-02; do
        get_subdomain_info $domain $sub
    done
else
    # If a subdomain is specified, show only that
    get_subdomain_info $domain $subdomain
fi
