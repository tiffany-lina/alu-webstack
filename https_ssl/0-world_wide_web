#!/bin/bash

# Function to display subdomain info
display_subdomain() {
    local domain=$1
    local subdomain=$2
    local ip=""

    # Map subdomains to IPs
    case $subdomain in
        www|lb-01)
            ip="44.212.25.228"
            ;;
        web-01)
            ip="34.203.218.185"
            ;;
        web-02)
            ip="44.202.164.145"
            ;;
    esac

    # Use dig with nip.io
    local result=$(dig $subdomain.$ip.nip.io | grep -A1 'ANSWER SECTION:' | awk '/IN/ {print $5}')
    echo "The subdomain $subdomain is a A record and points to $result"
}

domain=$1
subdomain=$2

# Default subdomains order
subdomains=("www" "lb-01" "web-01" "web-02")

if [ -z "$subdomain" ]; then
    for sub in "${subdomains[@]}"; do
        display_subdomain $domain $sub
    done
else
    display_subdomain $domain $subdomain
fi
