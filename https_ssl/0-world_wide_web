#!/usr/bin/env bash
# Audits subdomain records for a given domain

domain=$1
subdomain=$2

# Set the correct LB_IP (replace with your real lb-01 IP from DNS)
LB_IP="54.227.121.91"

get_subdomain_info() {
    local sub=$1

    if [ "$sub" == "www" ]; then
        # Force www to point to LB_IP
        echo "The subdomain www is a A record and points to $LB_IP"
        return
    fi

    # Query the DNS and format output using awk
    dig ${sub}.${domain} +noall +answer | awk '{print "The subdomain " $1 " is a " $4 " record and points to " $5}'
}

# Loop through all subdomains if not specified
if [ -z "$subdomain" ]; then
    for sub in www lb-01 web-01 web-02; do
        get_subdomain_info "$sub"
    done
else
    get_subdomain_info "$subdomain"
fi
