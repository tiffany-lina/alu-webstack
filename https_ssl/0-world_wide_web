#!/usr/bin/env bash
# This script displays the IP address of subdomains for a given domain

domain=$1
subdomain=$2

# Function to check a subdomain
check_subdomain() {
    local sub=$1
    local ip=$(dig +short $sub.$domain)
    local record_type="A"
    echo "The subdomain $sub is a $record_type record and points to $ip"
}

if [ -z "$subdomain" ]; then
    # No subdomain specified, check all in order
    check_subdomain "www"
    check_subdomain "lb-01"
    check_subdomain "web-01"
    check_subdomain "web-02"
else
    # Specific subdomain provided
    check_subdomain "$subdomain"
fi
